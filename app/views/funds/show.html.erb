<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
      <i class="fas fa-fund-diagram me-2"></i>
      <%= @fund.name %>
      <%= active_badge(@fund.active?, css_class: "ms-2") %>
    </h1>
    <div>
      <%= link_to edit_fund_path(@fund), class: "btn btn-primary" do %>
        <i class="fas fa-edit me-1"></i><%= t('funds.show.edit') %>
      <% end %>
      <%= link_to funds_path, class: "btn btn-secondary ms-2" do %>
        <i class="fas fa-arrow-left me-1"></i><%= t('funds.show.back') %>
      <% end %>
    </div>
  </div>

  <div class="row">
    <!-- Informazioni Progetto -->
    <div class="col-md-4">
      <div class="card shadow-sm mb-4">
        <div class="card-header">
          <h5 class="mb-0"><i class="fas fa-info-circle me-1"></i><%= t('funds.show.project_info') %></h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <strong><i class="fas fa-tag me-1"></i><%= t('funds.show.name_label') %></strong><br>
            <span class="fs-5"><%= @fund.name %></span>
          </div>
          
          <div class="mb-3">
            <strong><i class="fas fa-euro-sign me-1"></i><%= t('funds.show.budget_label') %></strong><br>
            <span class="fs-5 text-primary">€ <%= number_with_precision(@fund.budget, precision: 2) %></span>
          </div>
          
          <div class="mb-3">
            <strong><i class="fas fa-toggle-on me-1"></i><%= t('funds.show.status_label') %></strong><br>
            <% if @fund.active? %>
              <span class="badge bg-success fs-6">
                <i class="fas fa-check me-1"></i><%= t('funds.show.active') %>
              </span>
            <% else %>
              <span class="badge bg-secondary fs-6">
                <i class="fas fa-times me-1"></i><%= t('funds.show.inactive') %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Statistiche Budget -->
    <div class="col-md-4">
      <div class="card shadow-sm mb-4">
        <div class="card-header">
          <h5 class="mb-0"><i class="fas fa-chart-pie me-1"></i><%= t('funds.show.budget_stats') %></h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <strong><%= t('funds.show.total_expenses') %></strong><br>
            <span class="fs-5 <%= @fund.over_budget? ? 'text-danger' : 'text-success' %>">
              € <%= number_with_precision(@fund.total_expenses, precision: 2) %>
            </span>
          </div>
          
          <div class="mb-3">
            <strong><%= t('funds.show.remaining_budget') %></strong><br>
            <span class="fs-5 <%= @fund.remaining_budget < 0 ? 'text-danger' : 'text-success' %>">
              € <%= number_with_precision(@fund.remaining_budget, precision: 2) %>
            </span>
          </div>
          
          <div class="mb-3">
            <strong><%= t('funds.show.percent_used') %></strong><br>
            <div class="progress mb-2" style="height: 25px;">
              <div class="progress-bar <%= @fund.over_budget? ? 'bg-danger' : 'bg-success' %>" 
                   role="progressbar" 
                   style="width: <%= [@fund.budget_percentage_used, 100].min %>%"
                   aria-valuenow="<%= @fund.budget_percentage_used %>" 
                   aria-valuemin="0" 
                   aria-valuemax="100">
                <%= @fund.budget_percentage_used %>%
              </div>
            </div>
                <% if @fund.over_budget? %>
              <small class="text-danger">
                <i class="fas fa-exclamation-triangle me-1"></i>
                <%= t('funds.show.over_budget') %>
              </small>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Riepilogo Spese -->
    <div class="col-md-4">
      <div class="card shadow-sm mb-4">
        <div class="card-header">
          <h5 class="mb-0"><i class="fas fa-receipt me-1"></i><%= t('funds.show.expense_summary') %></h5>
        </div>
        <div class="card-body">
          <div class="mb-3">
            <strong><%= t('funds.show.total_count') %></strong><br>
            <span class="fs-5 text-info"><%= @fund.expenses.count %></span>
          </div>
          
          <div class="mb-3">
            <strong><%= t('funds.show.approved_count') %></strong><br>
            <span class="fs-5 text-success"><%= @fund.expenses.status_approved.count %></span>
          </div>
          
          <div class="mb-3">
            <strong><%= t('funds.show.pending_count') %></strong><br>
            <span class="fs-5 text-warning"><%= @fund.expenses.status_created.count %></span>
          </div>
          
          <div class="mb-3">
            <strong><%= t('funds.show.denied_count') %></strong><br>
            <span class="fs-5 text-danger"><%= @fund.expenses.status_denied.count %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Lista Spese del Progetto -->
  <div class="row">
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-header">
          <h5 class="mb-0"><i class="fas fa-list me-1"></i><%= t('funds.show.expense_list') %></h5>
        </div>
        <div class="card-body">
          <% if @fund.expenses.any? %>
            <div class="table-responsive">
              <table class="table table-hover">
                <thead class="table-light">
                  <tr>
                    <th><%= t('funds.show.date_th') %></th>
                    <th><%= t('funds.show.description_th') %></th>
                    <th><%= t('funds.show.amount_th') %></th>
                    <th><%= t('funds.show.type_th') %></th>
                    <th><%= t('funds.show.status_th') %></th>
                    <th><%= t('funds.show.reimbursement_th') %></th>
                  </tr>
                </thead>
                <tbody>
                  <% @fund.expenses.order(date: :desc).each do |expense| %>
                    <tr>
                      <td><%= expense.date.strftime("%d/%m/%Y") %></td>
                      <td><%= expense.purpose %></td>
                      <td class="text-end">
                        <strong>€ <%= number_with_precision(expense.amount, precision: 2) %></strong>
                      </td>
                      <td>
                        <% if expense.car? %>
                          <span class="badge bg-info"><%= t('funds.show.car_type') %></span>
                        <% else %>
                          <span class="badge bg-secondary"><%= t('funds.show.normal_type') %></span>
                        <% end %>
                      </td>
                      <td>
                        <%= status_badge(expense.status, :expense) %>
                      </td>
                      <td>
                          <%= link_to expense.reimboursement, class: "btn btn-sm btn-outline-primary" do %>
                          <i class="fas fa-external-link-alt me-1"></i>
                          <%= t('funds.show.reimbursement_th') %> #<%= expense.reimboursement.id %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5">
              <i class="fas fa-receipt fa-3x text-muted mb-3"></i>
              <h5 class="text-muted"><%= t('funds.show.empty_expenses') %></h5>
              <p class="text-muted"><%= t('funds.show.empty_expenses_text') %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
