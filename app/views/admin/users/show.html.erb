<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1><%= t('.title') %></h1>
    <% if @user.active? %>
      <span class="badge bg-success fs-6"><%= t('.status.active') %></span>
    <% else %>
      <span class="badge bg-danger fs-6"><%= t('.status.deactivated') %></span>
    <% end %>
  </div>
  
  <div class="card">
    <div class="card-body">
      <h5 class="card-title"><%= @user.name %> <%= @user.surname %></h5>
      
      <div class="row">
        <div class="col-md-6">
          <p><strong><%= t('.email_label') %>:</strong> <%= @user.email %></p>
          <p><strong><%= t('.phone_label') %>:</strong> <%= @user.telephone %></p>
          <p><strong><%= t('.fiscal_code_label') %>:</strong> <%= @user.fiscal_code %></p>
        </div>
        <div class="col-md-6">
          <p><strong><%= t('.role_label') %>:</strong> <%= @user.role&.label || t('.no_role') %></p>
          <p><strong><%= t('.admin_label') %>:</strong> 
            <% if @user.admin? %>
              <span class="badge bg-success"><%= t('.yes') %></span>
            <% else %>
              <span class="badge bg-secondary"><%= t('.no') %></span>
            <% end %>
          </p>
          <p><strong><%= t('.registered_label') %>:</strong> <%= @user.created_at.strftime("%d/%m/%Y") %></p>
          <p><strong><%= t('.account_status_label') %>:</strong> 
            <% if @user.active? %>
              <span class="badge bg-success"><%= t('.status.active') %></span>
            <% else %>
              <span class="badge bg-danger"><%= t('.status.deactivated') %></span>
            <% end %>
          </p>
        </div>
      </div>
      
      <!-- Statistiche rimborsi -->
      <hr>
      <div class="row">
        <div class="col-md-12">
          <h6><%= t('.stats_title') %></h6>
          <p><strong><%= t('.total_reimbursements') %>:</strong> 
            <span class="badge bg-<%= @user.reimboursements.any? ? 'warning' : 'secondary' %>">
              <%= @user.reimboursements.count %>
            </span>
          </p>
          <% if @user.reimboursements.any? %>
            <p><strong><%= t('.total_amount') %>:</strong> 
              € <%= number_with_precision(@user.reimboursements.sum(&:total_amount), precision: 2) %>
            </p>
          <% end %>
        </div>
      </div>
      
      <div class="mt-3">
        <%= link_to t('admin.users.show.edit'), edit_admin_user_path(@user), class: 'btn btn-warning' %>
        
        <% unless @user == current_user %>
            <% if @user.active? %>
            <%= link_to t('.deactivate'), deactivate_admin_user_path(@user), method: :patch,
                        data: { confirm: t('.deactivate_confirm') },
                        class: 'btn btn-outline-warning' %>
          <% else %>
            <%= link_to t('.activate'), activate_admin_user_path(@user), method: :patch,
                        class: 'btn btn-outline-success' %>
          <% end %>
          
            <% if @user.can_be_deleted? %>
            <%= link_to t('.delete'), admin_user_path(@user), method: :delete,
                        data: { confirm: t('.delete_confirm') },
                        class: 'btn btn-outline-danger' %>
          <% else %>
            <span class="btn btn-secondary disabled" title="<%= t('.has_reimbursements') %>">
              <i class="fas fa-ban"></i> <%= t('.not_deletable') %>
            </span>
          <% end %>
        <% end %>
        
        <%= link_to t('common.actions.back'), admin_users_path, class: 'btn btn-secondary' %>
      </div>
    </div>
  </div>
</div>
