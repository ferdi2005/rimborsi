<div class="container-fluid">
  <h1><%= t('admin.users.edit.title', name: @user.name, surname: @user.surname) %></h1>
  
  <%= form_with(model: [:admin, @user], local: true, class: "row g-3") do |form| %>
    <% if @user.errors.any? %>
      <div class="alert alert-danger">
        <h4><%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:</h4>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="col-md-6">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :surname, class: "form-label" %>
      <%= form.text_field :surname, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :telephone, class: "form-label" %>
      <%= form.number_field :telephone, class: "form-control" %>
    </div>

    <div class="col-md-6">
      <%= form.label :fiscal_code, t('admin.users.edit.fiscal_code_label'), class: "form-label" %>
      <%= form.text_field :fiscal_code, class: "form-control", required: true,
                          title: t('admin.users.edit.fiscal_code_title'),
                          style: "text-transform: uppercase;" %>
    </div>

    <div class="col-md-6">
      <%= form.label :role_id, t('admin.users.edit.role_label'), class: "form-label" %>
      <%= form.collection_select :role_id, Role.all, :id, :label, { prompt: t('admin.users.edit.select_role_prompt') }, { class: "form-select" } %>
    </div>

    <div class="col-md-6">
      <div class="form-check mt-4">
        <%= form.check_box :active, class: "form-check-input" %>
        <%= form.label :active, t('admin.users.edit.account_active_label'), class: "form-check-label" %>
        <small class="form-text text-muted d-block"><%= t('admin.users.edit.account_active_help') %></small>
      </div>
    </div>

    <div class="col-12">
      <%= form.submit t('admin.users.edit.update_user'), class: "btn btn-primary" %>
      <%= link_to t('common.actions.cancel'), admin_user_path(@user), class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>
