<%= form_with(model: bank_account, class: "row g-3") do |form| %>
  <% if bank_account.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <h6><%= pluralize(bank_account.errors.count, "errore", "errori") %> ha impedito il salvataggio:</h6>
        <ul class="mb-0">
          <% bank_account.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <% if current_user.admin? %>
    <div class="col-md-6">
      <%= form.label :user_id, t('bank_accounts.form.user_label'), class: "form-label" %>
      <%= form.collection_select :user_id, User.all, :id, 
                                ->(user) { "#{user.name} #{user.surname} (#{user.email})" }, 
                                { prompt: t('bank_accounts.form.select_user') }, 
                                { class: "form-select", required: true } %>
    </div>
  <% else %>
    <%= form.hidden_field :user_id, value: current_user.id %>
  <% end %>

  <div class="col-md-6">
    <%= form.label :iban, t('bank_accounts.form.iban_label'), class: "form-label" %>
    <%= form.text_field :iban, class: "form-control", required: true,
                        pattern: "[A-Z]{2}[0-9]{2}[A-Z0-9]{1,30}",
                        title: t('bank_accounts.form.iban_help'),
                        placeholder: t('bank_accounts.form.iban_placeholder'),
                        style: "text-transform: uppercase;",
                        id: "bank_account_iban" %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.iban_help') %></small>
  </div>

  <div class="col-md-6">
    <%= form.label :owner, t('bank_accounts.form.owner_label'), class: "form-label" %>
    <%= form.text_field :owner, class: "form-control", required: true,
                        minlength: 2, maxlength: 100 %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.owner_help') %></small>
  </div>

  <div class="col-md-6">
    <%= form.label :bank_name, t('bank_accounts.form.bank_name_label'), class: "form-label" %>
    <%= form.text_field :bank_name, class: "form-control",
                        minlength: 2, maxlength: 100,
                        placeholder: t('bank_accounts.form.bank_name_help') %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.bank_name_help') %></small>
  </div>

  <div class="col-md-6">
    <%= form.label :bic_swift, t('bank_accounts.form.bic_swift_label'), class: "form-label" %>
    <%= form.text_field :bic_swift, class: "form-control",
                        placeholder: t('bank_accounts.form.bic_swift_help'),
                        style: "text-transform: uppercase;" %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.bic_swift_help') %></small>
  </div>

  <div class="col-md-8">
    <%= form.label :address, t('bank_accounts.form.address_label'), class: "form-label" %>
    <%= form.text_field :address, class: "form-control" %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.address_help') %></small>
  </div>

  <div class="col-md-4">
    <%= form.label :cap, t('bank_accounts.form.cap_label'), class: "form-label" %>
    <%= form.text_field :cap, class: "form-control", pattern: "[0-9]{5}", title: t('bank_accounts.form.cap_help') %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.cap_help') %></small>
  </div>

  <div class="col-md-6">
    <%= form.label :town, t('bank_accounts.form.town_label'), class: "form-label" %>
    <%= form.text_field :town, class: "form-control" %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.town_help') %></small>
  </div>

  <div class="col-md-6">
    <%= form.label :fiscal_code, t('bank_accounts.form.fiscal_code_label'), class: "form-label" %>
    <%= form.text_field :fiscal_code, class: "form-control", title: t('bank_accounts.form.fiscal_code_help') %>
    <small class="form-text text-muted"><%= t('bank_accounts.form.fiscal_code_help') %></small>
  </div>

  <div class="col-12">
    <div class="form-check">
      <%= form.check_box :default, class: "form-check-input" %>
      <%= form.label :default, t('bank_accounts.form.default_label'), class: "form-check-label" %>
    </div>
    <small class="form-text text-muted"><%= t('bank_accounts.form.default_help') %></small>
  </div>

  <div class="col-12">
    <%= form.submit t('bank_accounts.form.save'), class: 'btn btn-primary' %>
    <%= link_to t('bank_accounts.form.cancel'), bank_accounts_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
