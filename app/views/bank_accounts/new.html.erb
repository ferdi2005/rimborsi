<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <h2 class="mb-0"><%= t('bank_accounts.new.title') %></h2>
        </div>
        <div class="card-body">
          <%= render 'form', bank_account: @bank_account %>
        </div>
        <div class="card-footer">
          <%= link_to t('bank_accounts.new.back'), bank_accounts_path, class: "btn btn-secondary" %>
        </div>
      </div>
    </div>
  </div>
</div>
