<div class="container">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <h2 class="mb-0"><%= t('devise.registrations.edit.title', resource: t('layouts.navbar.profile')) %></h2>
        </div>
        <div class="card-body">
          <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "row g-3" }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <%= render "devise/registrations/user_fields", f: f %>

            <% if current_user.admin? %>
              <div class="col-md-6">
                <%= f.label :role_id, t('devise.registrations.edit.role_label'), class: "form-label" %>
                <%= f.collection_select :role_id, Role.all, :id, :label, { prompt: t('devise.registrations.edit.select_role_prompt') }, { class: "form-select" } %>
              </div>
            <% else %>
              <div class="col-md-6">
                <%= f.label :role_id, t('devise.registrations.edit.role_label'), class: "form-label" %>
                <p class="form-control-plaintext"><%= current_user.role&.label || t('devise.registrations.edit.no_role_assigned') %></p>
              </div>
            <% end %>

            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="col-12">
                <div class="alert alert-info">
                  In attesa di conferma per: <%= resource.unconfirmed_email %>
                </div>
              </div>
            <% end %>

            <div class="col-md-6">
              <%= f.label :password, t('devise.registrations.edit.password_label'), class: "form-label" %>
              <small class="form-text text-muted"><%= t('devise.registrations.edit.leave_blank_if_you_don_t_want_to_change_it') %></small>
              <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
              <% if @minimum_password_length %>
                <small class="form-text text-muted"><%= t('devise.registrations.edit.password_min_length', count: @minimum_password_length) %></small>
              <% end %>
            </div>

            <div class="col-md-6">
              <%= f.label :password_confirmation, t('devise.registrations.edit.password_confirmation_label'), class: "form-label" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
            </div>

            <div class="col-12">
              <%= f.label :current_password, t('devise.registrations.edit.current_password_label'), class: "form-label" %>
              <small class="form-text text-muted"><%= t('devise.registrations.edit.current_password_help') %></small>
              <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", required: true %>
            </div>

            <div class="col-12">
              <%= f.submit t('common.actions.update'), class: "btn btn-primary" %>
              <%= link_to t('common.actions.back'), :back, class: "btn btn-secondary" %>
            </div>
          <% end %>
        </div>
        <div class="card-footer text-center">
          <p class="text-muted mb-0">
            <i class="fas fa-info-circle"></i> 
            <%= t('devise.registrations.edit.footer_contact') %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
