<div class="container-fluid py-4">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
      <div class="card shadow">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <h2 class="h4 text-gray-900 mb-0"><%= t('devise.passwords.edit.title') %></h2>
            <p class="text-muted small mt-2"><%= t('devise.passwords.edit.subtitle') %></p>
          </div>

          <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "needs-validation", novalidate: true }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>
            <%= f.hidden_field :reset_password_token %>

            <div class="mb-3">
              <%= f.label :password, t('devise.passwords.edit.new_password_label'), class: "form-label" %>
              <% if @minimum_password_length %>
                <small class="form-text text-muted d-block">
                  <em>(<%= t('devise.passwords.edit.min_length', count: @minimum_password_length) %>)</em>
                </small>
              <% end %>
              <%= f.password_field :password, 
                  autofocus: true, 
                  autocomplete: "new-password",
                  class: "form-control",
                  placeholder: t('devise.passwords.edit.password_placeholder'),
                  minlength: @minimum_password_length,
                  required: true %>
              <div class="invalid-feedback">
                <%= t('devise.passwords.edit.password_invalid', count: @minimum_password_length || 6) %>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, t('devise.passwords.edit.confirm_label'), class: "form-label" %>
              <%= f.password_field :password_confirmation, 
                  autocomplete: "new-password",
                  class: "form-control",
                  placeholder: t('devise.passwords.edit.confirm_placeholder'),
                  required: true %>
              <div class="invalid-feedback">
                <%= t('devise.passwords.edit.password_mismatch') %>
              </div>
            </div>

            <div class="d-grid">
                <%= f.submit t('devise.passwords.edit.submit'), 
                  class: "btn btn-primary btn-block" %>
            </div>
          <% end %>

          <hr class="my-4">

          <div class="text-center">
            <%= render "devise/shared/links" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
// Validazione client-side per conferma password
document.addEventListener('DOMContentLoaded', function() {
  const passwordField = document.querySelector('input[name="user[password]"]');
  const confirmField = document.querySelector('input[name="user[password_confirmation]"]');
  
  if (passwordField && confirmField) {
    function validatePasswordMatch() {
      if (confirmField.value && passwordField.value !== confirmField.value) {
        confirmField.setCustomValidity('<%= j t('devise.passwords.edit.password_mismatch') %>');
      } else {
        confirmField.setCustomValidity('');
      }
    }
    
    passwordField.addEventListener('input', validatePasswordMatch);
    confirmField.addEventListener('input', validatePasswordMatch);
  }
});
</script>
