<%= form_with(model: vehicle, class: "row g-3") do |form| %>
  <% if vehicle.errors.any? %>
    <div class="col-12">
      <div class="alert alert-danger">
        <h6><%= pluralize(vehicle.errors.count, "errore", "errori") %> ha impedito il salvataggio:</h6>
        <ul class="mb-0">
          <% vehicle.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <% if current_user.admin? %>
    <div class="col-md-6">
      <%= form.label :user_id, t('vehicles.form.user_label'), class: "form-label" %>
      <%= form.collection_select :user_id, User.all, :id, 
                                ->(user) { "#{user.name} #{user.surname} (#{user.email})" }, 
                                { prompt: t('vehicles.form.select_user') }, 
                                { class: "form-select", required: true } %>
    </div>
  <% else %>
    <%= form.hidden_field :user_id, value: current_user.id %>
  <% end %>

  <div class="col-md-6">
    <%= form.label :name, t('vehicles.form.name_label'), class: "form-label" %>
    <%= form.text_field :name, class: "form-control", required: true, placeholder: t('vehicles.form.name_help') %>
    <small class="form-text text-muted"><%= t('vehicles.form.name_help') %></small>
  </div>

  <div class="col-md-4">
    <%= form.label :vehicle_category, t('vehicles.form.category_label'), class: "form-label" %>
    <%= form.select :vehicle_category, 
                    options_for_select([
                      ['Autovettura', 'autovettura'],
                      ['Fuoristrada/SUV', 'fuoristrada_suv'],
                      ['Motociclo', 'motociclo'],
                      ['Ciclomotore', 'ciclomotore'],
                      ['Autofurgone', 'autofurgone'],
                      ['Autocaravan', 'autocaravan']
                    ], vehicle.vehicle_category), 
                    { prompt: t('vehicles.form.select_category') }, 
                    { class: "form-select", required: true } %>
  </div>

  <div class="col-md-4">
    <%= form.label :brand, t('vehicles.form.brand_label'), class: "form-label" %>
    <%= form.text_field :brand, class: "form-control", required: true, placeholder: t('vehicles.form.brand_label') %>
  </div>

  <div class="col-md-4">
    <%= form.label :model, t('vehicles.form.model_label'), class: "form-label" %>
    <%= form.text_field :model, class: "form-control", required: true, placeholder: t('vehicles.form.model_label') %>
  </div>

  <div class="col-md-8">
    <%= form.label :fuel_type, t('vehicles.form.fuel_label'), class: "form-label" %>
    <%= form.select :fuel_type, 
                    options_for_select([
                      ['Altro', 'altro'],
                      ['Benzina e gas liquido', 'benzina_e_gas_liquido'],
                      ['Benzina e metano', 'benzina_e_metano'],
                      ['Benzina verde', 'benzina_verde'],
                      ['Elettrica', 'elettrica'],
                      ['Gasolio', 'gasolio'],
                      ['Ibrido-benzina', 'ibrido_benzina'],
                      ['Ibrido-gasolio', 'ibrido_gasolio'],
                      ['Ibrido plugin-benzina', 'ibrido_plugin_benzina'],
                      ['Metano esclusivo', 'metano_esclusivo']
                    ], vehicle.fuel_type), 
                    { prompt: t('vehicles.form.select_fuel') }, 
                    { class: "form-select", required: true } %>
  </div>

  <div class="col-12">
    <div class="form-check">
      <%= form.check_box :default, class: "form-check-input" %>
      <%= form.label :default, t('vehicles.form.default_label'), class: "form-check-label" %>
    </div>
    <small class="form-text text-muted"><%= t('vehicles.form.default_help') %></small>
  </div>

  <div class="col-12">
    <%= form.submit t('vehicles.form.save'), class: 'btn btn-primary' %>
    <%= link_to t('vehicles.form.cancel'), vehicles_path, class: 'btn btn-secondary' %>
  </div>
<% end %>
