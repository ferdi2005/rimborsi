<%= t('mailers.reimboursement.status_changed.subject') %>

<%= t('mailers.reimboursement.status_changed.greeting', name: @user.name) %>

<%= t('mailers.reimboursement.status_changed.updated_message', id: @reimboursement.id) %>

<%= t('mailers.reimboursement.status_changed.new_status') %> <%= @reimboursement.status_in_italian %>

<% if @note&.text.present? %>
<%= t('mailers.reimboursement.status_changed.admin_note') %>
<%= t('mailers.reimboursement.status_changed.author', name: @author.name, surname: @author.surname) %>
<%= t('mailers.reimboursement.status_changed.date', date: @note.created_at.strftime("%d/%m/%Y alle %H:%M")) %>

<%= @note.text %>
<% end %>

<%= t('mailers.reimboursement.status_changed.total', total: number_with_precision(@reimboursement.total_amount, precision: 2)) %>

<%= t('mailers.reimboursement.status_changed.signature') %>
<% admin_email = ENV['EMAIL_AMMINISTRAZIONE'] || ENV["ADDRESS"] %>
<%= t('mailers.reimboursement.status_changed.contact', email: admin_email) %>
<%= t('mailers.reimboursement.status_changed.reply_request') %>

<%= t('mailers.reimboursement.status_changed.links') %>
- <%= t('mailers.reimboursement.status_changed.view_reimbursement') %>: <%= reimboursement_url(@reimboursement) %>
- <%= t('mailers.reimboursement.status_changed.all_reimbursements') %>: <%= reimboursements_url %>
