<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background-color: #007bff;
        color: white;
        padding: 20px;
        text-align: center;
        border-radius: 5px 5px 0 0;
      }
      .content {
        background-color: #f8f9fa;
        padding: 20px;
        border: 1px solid #dee2e6;
      }
      .note {
        background-color: white;
        padding: 15px;
        border-left: 4px solid #007bff;
        margin: 15px 0;
      }
      .footer {
        background-color: #6c757d;
        color: white;
        padding: 15px;
        text-align: center;
        font-size: 12px;
        border-radius: 0 0 5px 5px;
      }
      .btn {
        display: inline-block;
        background-color: #007bff;
        color: white;
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 5px;
        margin: 10px 0;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1><%= t('mailers.reimboursement.note_added.title', id: @reimboursement.id) %></h1>
    </div>
    
    <div class="content">
      <p><%= t('mailers.reimboursement.note_added.greeting', name: @user.name) %></p>
      
      <p><%= t('mailers.reimboursement.note_added.new_note_message', id: @reimboursement.id) %></p>
      
      <div class="note">
        <p><strong><%= t('mailers.reimboursement.note_added.author') %>:</strong> <%= @author.name %> <%= @author.surname %></p>
        <p><strong><%= t('mailers.reimboursement.note_added.date') %>:</strong> <%= @note.created_at.strftime("%d/%m/%Y #{I18n.t('common.at_time')} %H:%M") %></p>
        <% if @note.status_change.present? %>
          <p><strong><%= t('mailers.reimboursement.note_added.status_change') %>:</strong> <%= Reimboursement.status_translations[@note.status_change] %></p>
        <% end %>
        <p><strong><%= t('mailers.reimboursement.note_added.content') %>:</strong></p>
        <p><%= simple_format(@note.text) %></p>
      </div>
      
      <p>
        <strong><%= t('mailers.reimboursement.note_added.current_status_label') %>:</strong>
        <%= @reimboursement.status_in_italian %>
      </p>
      
      <p>
        <strong><%= t('mailers.reimboursement.note_added.total_label') %>:</strong>
        € <%= number_with_precision(@reimboursement.total_amount, precision: 2) %>
      </p>
    </div>
    
    <div class="footer">
      <p><strong>Wikimedia Italia - Gestione rimborsi</strong></p>
      <% admin_email = ENV['EMAIL_AMMINISTRAZIONE'] || ENV["ADDRESS"] %>
      <p>
        <%= t('mailers.reimboursement.note_added.contact_label') %>: <a href="mailto:<%= admin_email %>" style="color: white;"><%= admin_email %></a><br>
        <%= t('mailers.reimboursement.note_added.reply_request') %>
      </p>
      <p style="margin-top: 15px;">
        <a href="<%= reimboursement_url(@reimboursement) %>" style="color: white; text-decoration: underline;">
          🔗 <%= t('mailers.reimboursement.note_added.view_reimbursement') %>
        </a> | 
        <a href="<%= reimboursements_url %>" style="color: white; text-decoration: underline;">
          📋 <%= t('mailers.reimboursement.note_added.all_reimbursements') %>
        </a>
      </p>
    </div>
  </body>
</html>