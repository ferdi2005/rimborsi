<%= t('mailers.reimboursement.note_added.subject', id: @reimboursement.id) %>

<%= t('mailers.reimboursement.note_added.greeting', name: @user.name) %>

<%= t('mailers.reimboursement.note_added.new_note_message', id: @reimboursement.id) %>

<%= t('mailers.reimboursement.note_added.details') %>
<%= t('mailers.reimboursement.note_added.author', name: @author.name, surname: @author.surname) %>
<%= t('mailers.reimboursement.note_added.date', date: @note.created_at.strftime("%d/%m/%Y alle %H:%M")) %>
<% if @note.status_change.present? %>
<%= t('mailers.reimboursement.note_added.status_change', status: Reimboursement.status_translations[@note.status_change]) %>
<% end %>

<%= t('mailers.reimboursement.note_added.content') %>
<%= @note.text %>

<%= t('mailers.reimboursement.note_added.current_status', status: @reimboursement.status_in_italian) %>
<%= t('mailers.reimboursement.note_added.total', total: number_with_precision(@reimboursement.total_amount, precision: 2)) %>

<%= t('mailers.reimboursement.note_added.signature') %>
<% admin_email = ENV['EMAIL_AMMINISTRAZIONE'] || ENV["ADDRESS"] %>
<%= t('mailers.reimboursement.note_added.contact', email: admin_email) %>
<%= t('mailers.reimboursement.note_added.reply_request') %>

<%= t('mailers.reimboursement.note_added.links') %>
- <%= t('mailers.reimboursement.note_added.view_reimbursement') %>: <%= reimboursement_url(@reimboursement) %>
- <%= t('mailers.reimboursement.note_added.all_reimbursements') %>: <%= reimboursements_url %>
