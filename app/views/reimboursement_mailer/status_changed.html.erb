<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background-color: #28a745;
        color: white;
        padding: 20px;
        text-align: center;
        border-radius: 5px 5px 0 0;
      }
      .content {
        background-color: #f8f9fa;
        padding: 20px;
        border: 1px solid #dee2e6;
      }
      .status-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: bold;
        color: white;
        background-color: #007bff;
      }
      .note {
        background-color: white;
        padding: 15px;
        border-left: 4px solid #28a745;
        margin: 15px 0;
      }
      .footer {
        background-color: #6c757d;
        color: white;
        padding: 15px;
        text-align: center;
        font-size: 12px;
        border-radius: 0 0 5px 5px;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1><%= t('mailers.reimboursement.status_changed.subject') %></h1>
    </div>
    
    <div class="content">
      <p><%= t('mailers.reimboursement.status_changed.greeting', name: @user.name) %></p>
      
      <p><%= t('mailers.reimboursement.status_changed.updated_message', id: @reimboursement.id) %></p>
      
      <p style="text-align: center;">
        <span class="status-badge">
          <%= t('mailers.reimboursement.status_changed.new_status') %> <%= @reimboursement.status_in_italian %>
        </span>
      </p>
      
      <% if @note&.text.present? %>
        <div class="note">
          <p><strong><%= t('mailers.reimboursement.status_changed.admin_note') %></strong></p>
          <p><strong><%= t('mailers.reimboursement.status_changed.author', name: @author.name, surname: @author.surname) %></strong></p>
          <p><strong><%= t('mailers.reimboursement.status_changed.date', date: @note.created_at.strftime("%d/%m/%Y alle %H:%M")) %></strong></p>
          <p><%= simple_format(@note.text) %></p>
        </div>
      <% end %>
      
      <p>
        <strong><%= t('mailers.reimboursement.status_changed.total', total: number_with_precision(@reimboursement.total_amount, precision: 2)) %></strong>
      </p>
    </div>
    
    <div class="footer">
      <p><strong><%= t('mailers.reimboursement.status_changed.signature') %></strong></p>
      <% admin_email = ENV['EMAIL_AMMINISTRAZIONE'] || ENV["ADDRESS"] %>
      <p>
        <%= t('mailers.reimboursement.status_changed.contact', email: admin_email) %><br>
        <%= t('mailers.reimboursement.status_changed.reply_request') %>
      </p>
      <p style="margin-top: 15px;">
        <a href="<%= reimboursement_url(@reimboursement) %>" style="color: white; text-decoration: underline;">
          <%= t('mailers.reimboursement.status_changed.view_reimbursement') %>
        </a> | 
        <a href="<%= reimboursements_url %>" style="color: white; text-decoration: underline;">
          <%= t('mailers.reimboursement.status_changed.all_reimbursements') %>
        </a>
      </p>
    </div>
  </body>
</html>