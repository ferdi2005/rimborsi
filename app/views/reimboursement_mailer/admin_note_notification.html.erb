<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        background-color: #dc3545;
        color: white;
        padding: 20px;
        text-align: center;
        border-radius: 5px 5px 0 0;
      }
      .content {
        background-color: #f8f9fa;
        padding: 20px;
        border: 1px solid #dee2e6;
      }
      .note {
        background-color: white;
        padding: 15px;
        border-left: 4px solid #dc3545;
        margin: 15px 0;
      }
      .user-info {
        background-color: #e9ecef;
        padding: 15px;
        border-radius: 5px;
        margin: 15px 0;
      }
      .footer {
        background-color: #6c757d;
        color: white;
        padding: 15px;
        text-align: center;
        font-size: 12px;
        border-radius: 0 0 5px 5px;
      }
      .btn {
        display: inline-block;
        background-color: #dc3545;
        color: white;
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 5px;
        margin: 10px 5px;
      }
      .btn-secondary {
        background-color: #6c757d;
      }
    </style>
  </head>
  <body>
    <div class="header">
      <h1>🔔 <%= t('mailers.reimboursement.admin_note_notification.title') %></h1>
      <p><%= t('mailers.reimboursement.admin_note_notification.reimbursement_number', id: @reimboursement.id) %></p>
    </div>
    
    <div class="content">
      <p><strong><%= t('mailers.reimboursement.admin_note_notification.new_note') %></strong></p>
      
      <div class="user-info">
        <h6><%= t('mailers.reimboursement.admin_note_notification.user_info') %></h6>
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.name') %>:</strong> <%= @user.name %> <%= @user.surname %></p>
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.email') %>:</strong> <%= @user.email %></p>
        <% if @user.telephone.present? %>
          <p><strong><%= t('mailers.reimboursement.admin_note_notification.phone') %>:</strong> <%= @user.telephone %></p>
        <% end %>
      </div>
      
      <div class="note">
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.note_added_on') %>:</strong> <%= @note.created_at.strftime("%d/%m/%Y #{I18n.t('common.at_time')} %H:%M") %></p>
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.content') %>:</strong></p>
        <p><%= simple_format(@note.text) %></p>
      </div>
      
      <div class="user-info">
        <h6><%= t('mailers.reimboursement.admin_note_notification.reimbursement_info') %></h6>
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.current_status') %>:</strong> <%= @reimboursement.status_in_italian %></p>
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.total') %>:</strong> € <%= number_with_precision(@reimboursement.total_amount, precision: 2) %></p>
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.payment_method') %>:</strong> <%= @reimboursement.payment_method_type %></p>
        <p><strong><%= t('mailers.reimboursement.admin_note_notification.expenses_count') %>:</strong> <%= @reimboursement.expenses.count %></p>
      </div>
      
      <p style="text-align: center; margin-top: 20px;">
        <a href="<%= reimboursement_url(@reimboursement) %>" class="btn">
          🔍 <%= t('mailers.reimboursement.admin_note_notification.view_reimbursement') %>
        </a>
        <a href="<%= reimboursements_url %>" class="btn btn-secondary">
          📋 <%= t('mailers.reimboursement.admin_note_notification.all_reimbursements') %>
        </a>
      </p>
    </div>
    
    <div class="footer">
      <p><strong><%= t('mailers.reimboursement.admin_note_notification.footer_title') %></strong></p>
      <p><%= t('mailers.reimboursement.admin_note_notification.footer_text') %></p>
    </div>
  </body>
</html>
